    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Empty path: effectively invisible icon on system splash -->
    <path
        android:pathData="M0,0h0v0h0z"
        android:fillColor="#00000000"/>
</vector>
